{
  "productName": "DeepData",
  "version": "0.1.0",
  "identifier": "com.deepdata.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "DeepData",
        "width": 1400,
        "height": 900,
        "center": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": [10, 10, 10, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src http://127.0.0.1:* http://localhost:* https://*; img-src 'self' data: http://127.0.0.1:* http://localhost:*; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/deepdata"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
